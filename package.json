{
	"name": "@yxw007/cimg-cli",
	"version": "0.0.0",
	"description": "An image compression CLI tool",
	"author": "yxw007<aa4790139@gmail.com>",
	"homepage": "https://github.com/yxw007/cimg-cli",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yxw007/cimg-cli.git"
	},
	"bugs": {
		"url": "https://github.com/yxw007/cimg-cli/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"cimg": "./bin/cimg.js"
	},
	"files": [
		"bin",
		"dist"
	],
	"scripts": {
		"lint": "oxlint . && oxfmt --check .",
		"lint:fix": "oxlint . --fix && oxfmt .",
		"build": "rolldown -c rolldown.config.mts",
		"dev": "rolldown -c rolldown.config.mts -w",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest --coverage --run",
		"prepublishOnly": "npm run build",
		"release": "pnpm changelogen --release -i",
		"prepare": "husky"
	},
	"dependencies": {
		"commander": "^13.1.0",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^19.8.1",
		"@types/node": "^22.20.1",
		"chalk": "^5.6.2",
		"changelogen": "^0.6.2",
		"commitlint": "^19.8.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.74.0",
		"rolldown": "^1.2.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.7"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"**/*.{ts}": [
			"pnpm lint:fix"
		]
	},
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"image",
		"compression",
		"cli",
		"png",
		"jpg",
		"gif"
	],
	"license": "MIT"
}
